#MISC
## web
alias aspirer='wget -r -k -E -np'
alias links='elinks'
alias ci='curl -I'
alias nload='nload eth0'
alias ports='netstat -lnptu'
alias purge='curl -IX BANURL'
## files
alias df='df -h'
alias dus='du --max-depth=1 -h'
alias duh='du -hsx'
alias less='less -r'
alias l='ls -CAF'
alias ll='ls -lAh'
alias lm='ls -lh'
alias ls='ls --color'
alias lr='ls -lARh'
alias tf='clear;tail -f -n 0'
## vim
alias vi='vim'
alias bim='vim'
alias cim='vim'

#CONFIG
alias bashrc='vim ~/.bashrc'
alias bashals='vim ~/.bash_aliases'
alias tmuxrc='vim ~/.tmux.conf'
alias vimrc='vim ~/.vimrc'

#GIT
alias ga='git add'
alias gaa='git add -A'
alias gc='git commit -m'
alias gca='git commit -am'
alias gd='git diff --color-words'
alias gl="git log --graph --all --decorate --pretty=format:'''%Cred%h%Creset -%C(yellow)%d%Creset %s %Cgreen(%cr) %C(cyan)<%an>%Creset'''"
alias glo='git log --graph --decorate --all'
alias gpl='git pull'
alias gpls='gpl && gps'
alias gps='git push'
alias gs='git status'
alias gcl='git clone --depth=1'
alias gco='git checkout'
alias gr='git reset HEAD'

# DRUSH
alias dcc='drush cc all'
alias den='drush en'
alias ddl='drush dl'
alias ddi='drush dis'
alias drm='drush pm-uninstall'
alias dup='drush up'
alias dupdb='drush updatedb'
alias dlist='drush pm-list | grep -vE -e "Not installed|Disabled" -e "Theme" | sed 1d | sed "s/Module  .*//g"'
alias dlog='drush watchdog-show'

# WP-CLI
alias wpl='wp plugin list'
alias wpu='wp core update && wp plugin update --all'
alias wpi='wp plugin install'
alias wpa='wp plugin activate'
alias wpd='wp plugin deactivate'
alias wpr='wp plugin delete'
alias wpreg='wp media regenerate --yes'
