#MISC
## web
alias aspirer='wget -r -k -E -np'
alias links='elinks'
alias ci='curl -I'
alias nload='nload eth0'
alias ports='netstat -lnptu'
alias purge='curl -IX BANURL'
## files
alias df='df -h'
alias dus='du --max-depth=1 -h'
alias duh='du -hsx'
alias less='less -r'
alias l='ls -CAF'
alias ll='ls -lAh'
alias lm='ls -lh'
alias ls='ls --color'
alias lr='ls -lARh'
alias tf='clear;tail -f -n 0'
## vim
alias vi='vim'
alias bim='vim'
alias cim='vim'

#LOGIN
alias dev='su - dev'
alias prod='su - prod'

#CONFIG
alias bashrc='vim ~/.bashrc'
alias bashals='vim ~/.bash_aliases'
alias screenrc='vim ~/.screenrc'
alias varrc='vim /etc/varnish/default.vcl'
alias vimrc='vim ~/.vimrc'

#MANAGEMENT
alias apar='systemctl restart apache2'
alias apal='systemctl reload apache2'
alias memr='systemctl restart memcache'
alias varr='systemctl restart varnish.service'

#FIREWALL
alias iedit='vim /etc/network/if-up.d/iptables'
alias ilist='iptables -nL'
alias iinit='/etc/network/if-up.d/iptables'

#PACKAGES
alias aclean='apt-get clean; apt-get autoremove; apt-get autoremove $(deborphan)'
alias ainstall='apt-get install'
alias asearch='apt-cache search'
alias ashow='apt-cache show'
alias aup='apt-get update ; apt-get dist-upgrade'
alias aremove='apt-get autoremove'
alias plg='dpkg --list | sed "s/ \(amd64\|all\)/ /g" | grep -i'
